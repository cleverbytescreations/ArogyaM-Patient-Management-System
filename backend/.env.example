# ArogyaM PMS — backend environment template (BE-TF.2).
#
# Copy to `.env` and supply real values. NEVER commit a populated .env.
# In production the app fails fast at startup if any secret below is left at its
# dev default (see app/core/config.py::_require_secrets_in_production).

# --- General ----------------------------------------------------------------
# development | production
ENV=development
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Database ---------------------------------------------------------------
# SQLAlchemy URL. In production must NOT contain the dev password.
# Least privilege (SEC-T0.3): in production the runtime should connect as the
# limited `arogyam_app` role (DML only, no DDL, append-only audit_log) created
# by backend/scripts/sql/least_privilege_app_role.sql — migrations run with a
# separate owner/admin URL. e.g. DATABASE_URL=...://arogyam_app:CHANGE_ME@db/...
DATABASE_URL=postgresql+psycopg://arogyam:CHANGE_ME@db:5432/arogyam
# Log every SQL statement. MUST be false outside local debugging (leaks PHI).
SQL_ECHO=false

# --- Object storage (MinIO / S3) --------------------------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=arogyam-documents
S3_USE_SSL=false

# --- Cache / rate-limiter (optional) ----------------------------------------
# Leave empty to disable the token denylist / rate limiting (single-process
# logout/refresh-rotation still works via the in-process fallback).
REDIS_URL=

# --- API --------------------------------------------------------------------
# Comma-separated allow-list of SPA origins. Wildcard is rejected in production.
CORS_ALLOW_ORIGINS=http://localhost:8080
UPLOAD_MAX_MB=10
AV_SCAN_ENABLED=false
AV_SCAN_COMMAND=

# --- Auth -------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_MIN=480

# --- Login lockout ----------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MIN=30

# --- Backup -----------------------------------------------------------------
# Path where the API writes the on-demand trigger file (shared with backup container).
BACKUP_TRIGGER_FILE=/backups/.trigger

# --- Audit log retention ----------------------------------------------------
# Hard-delete audit records older than this many days (7 years = 2555 days).
# Set to 0 to disable automatic purging entirely.
# Trigger via: POST /api/v1/audit-logs/purge  OR  scripts/purge_audit_log.py
AUDIT_RETENTION_DAYS=2555
