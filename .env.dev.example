# =============================================================================
# ArogyaM PMS — DEVELOPMENT environment template
# -----------------------------------------------------------------------------
# Copy to .env.dev and adjust as needed:   cp .env.dev.example .env.dev
# Used by:  docker compose -f docker-compose.dev.yml --env-file .env.dev up
#
# These are DEV-ONLY default credentials. They are intentionally weak for local
# convenience and must NEVER be reused in UAT/production. .env.dev is gitignored.
# =============================================================================

# --- General ---------------------------------------------------------------
ENV=development
TZ=UTC
LOG_LEVEL=DEBUG

# --- Container images (override to pin specific versions) ------------------
POSTGRES_IMAGE=postgres:16-alpine
MINIO_IMAGE=minio/minio:latest
MC_IMAGE=minio/mc:latest
REDIS_IMAGE=redis:7-alpine
NGINX_IMAGE=nginx:1.27-alpine

# --- Build targets (multi-stage Dockerfiles added with the app code) -------
API_BUILD_TARGET=dev
FRONTEND_BUILD_TARGET=dev

# --- Host port mappings (change if a port is already in use) ---------------
PROXY_HTTP_PORT=8080          # open the app at http://localhost:8080
API_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001       # MinIO console at http://localhost:9001
REDIS_PORT=6379

# --- Redis sizing ----------------------------------------------------------
REDIS_MAXMEMORY=128mb         # in-Redis cap; noeviction policy fails closed
REDIS_CPU_LIMIT=0.25          # container CPU limit
REDIS_MEM_LIMIT=192m          # container memory limit (> maxmemory for overhead)

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_DB=arogyam
POSTGRES_USER=arogyam
POSTGRES_PASSWORD=arogyam_dev_pw
DATABASE_URL=postgresql+psycopg://arogyam:arogyam_dev_pw@db:5432/arogyam

# --- MinIO / object storage ------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_pw
MINIO_BUCKET=arogyam-documents
S3_ENDPOINT_URL=http://minio:9000

# --- Redis URL (always-on in dev) ------------------------------------------
REDIS_URL=redis://redis:6379

# --- Backup -----------------------------------------------------------------
# How often (seconds) the backup container runs scheduled backups (default 1800 = 30 min).
# On-demand runs are always available via POST /api/v1/backup/trigger in the UI.
BACKUP_INTERVAL_SECONDS=1800

# --- Application config -----------------------------------------------------
CORS_ALLOW_ORIGINS=http://localhost:8080
VITE_API_BASE_URL=/api/v1
UPLOAD_MAX_MB=10
AV_SCAN_ENABLED=false
AV_SCAN_COMMAND=

# --- JWT (dev placeholders — generate per environment) ---------------------
# Generate a value with:  openssl rand -hex 32
JWT_SECRET_KEY=dev-only-change-me-0000000000000000000000000000000000000000
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_MIN=1440

# --- Bootstrap super-user (auto-created on startup by migration 0003) -------
# The ADMIN role grants every permission. If ADMIN_PASSWORD is left blank in a
# DEV environment a fallback password is used; in PRODUCTION a blank password
# skips creation (create the admin with backend/scripts/create_admin.py).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@12345
ADMIN_FULL_NAME=System Administrator
ADMIN_EMAIL=

# --- Audit log retention ----------------------------------------------------
# 2555 days = 7 years. Set 0 to disable. Trigger: POST /api/v1/audit-logs/purge
AUDIT_RETENTION_DAYS=2555
