# =============================================================================
# ArogyaM PMS — PRODUCTION environment template
# -----------------------------------------------------------------------------
# Copy to .env.prod and replace EVERY "CHANGE_ME" value:
#   cp .env.prod.example .env.prod && chmod 600 .env.prod
# Used by:  docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# SECURITY (SAD §10 — Secrets Management):
#   * .env.prod MUST be gitignored, chmod 600, owned by the deploy user.
#   * Generate strong random secrets:   openssl rand -hex 32
#   * Never commit real credentials, TLS keys, or SMTP passwords.
#   * For higher assurance, migrate these to Docker secrets / a secret manager.
# =============================================================================

# --- General ---------------------------------------------------------------
ENV=production
TZ=UTC
LOG_LEVEL=INFO

# Public URL of the deployment (used for CORS + redirects).
PUBLIC_BASE_URL=https://pms.arogyam.example.com
# Bare domain used by Nginx TLS / Let's Encrypt (no scheme).
DOMAIN=pms.arogyam.example.com

# --- Container images — PIN exact, tested versions -------------------------
REGISTRY=ghcr.io/your-org
API_IMAGE=arogyam-api
FRONTEND_IMAGE=arogyam-frontend
IMAGE_TAG=CHANGE_ME            # e.g. v1.0.0 (the release you tested in UAT)
POSTGRES_IMAGE=postgres:16-alpine
MINIO_IMAGE=minio/minio:RELEASE.2024-01-01T00-00-00Z   # CHANGE_ME: pin a tested release
MC_IMAGE=minio/mc:latest
REDIS_IMAGE=redis:7-alpine
NGINX_IMAGE=nginx:1.27-alpine
CERTBOT_IMAGE=certbot/certbot:latest
BACKUP_BASE_IMAGE=alpine:3.20

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_DB=arogyam
POSTGRES_USER=arogyam_app
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
# Optional dedicated read-only role for backups (recommended). Falls back to the
# app user if left unset.
BACKUP_PGUSER=
BACKUP_PGPASSWORD=

# --- MinIO / object storage ------------------------------------------------
MINIO_ROOT_USER=CHANGE_ME_minio_access_key
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_secret_key
MINIO_BUCKET=arogyam-documents
MINIO_BROWSER=off                       # keep the web console disabled in prod
S3_ENDPOINT_URL=http://minio:9000
S3_USE_SSL=false                        # internal hop is over the private network

# --- Redis -----------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_MAXMEMORY=256mb

# --- JWT / auth (SAD §10) --------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_MIN=1440

# --- Uploads ---------------------------------------------------------------
UPLOAD_MAX_MB=10

# --- SMTP (OPTIONAL — backup success/failure alerts, UC-26) ----------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_TO=admin@arogyam.example.com
# Optional generic webhook the backup scripts can POST a failure alert to:
ALERT_WEBHOOK_URL=

# --- Backups (SAD §18, UC-26/27) -------------------------------------------
# Absolute host path on a SEPARATE / off-server disk for backup storage.
# Must already exist (mkdir -p) and be writable by Docker.
BACKUP_HOST_PATH=/mnt/backup-disk/arogyam
BACKUP_RETENTION_DAYS=14
BACKUP_CRON_DB=0 2 * * *                 # nightly DB dump at 02:00
BACKUP_CRON_MINIO=0 3 * * *              # nightly document mirror at 03:00
BACKUP_LOG_TO_DB=true                    # record runs in the backup_log table

# --- Resource limits (tune to your VM — see deployment guide §2) -----------
DB_CPU_LIMIT=2.0
DB_MEM_LIMIT=2g
# FastAPI worker processes (multi-core). Rule of thumb: (2 x vCPU) + 1, capped
# to API_CPU_LIMIT. Recommended 4 vCPU box -> 4; minimum 2 vCPU box -> 2.
API_WORKERS=4
API_CPU_LIMIT=2.0
API_MEM_LIMIT=1536m
MINIO_CPU_LIMIT=1.0
MINIO_MEM_LIMIT=1g
REDIS_CPU_LIMIT=0.5
REDIS_MEM_LIMIT=384m
FRONTEND_CPU_LIMIT=0.5
FRONTEND_MEM_LIMIT=128m
PROXY_CPU_LIMIT=0.5
PROXY_MEM_LIMIT=128m